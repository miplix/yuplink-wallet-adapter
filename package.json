{
  "name": "@miplix/yuplink-wallet-adapter",
  "version": "0.1.0",
  "description": "NEAR wallet-selector adapter for YupLink Wallet (service.yupland.io)",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "near",
    "near-protocol",
    "wallet-selector",
    "yuplink",
    "wallet"
  ],
  "author": "miplix",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/miplix/yuplink-wallet-adapter.git"
  },
  "homepage": "https://service.yupland.io/wallet/docs",
  "bugs": {
    "url": "https://github.com/miplix/yuplink-wallet-adapter/issues"
  },
  "peerDependencies": {
    "@near-wallet-selector/core": "^8.0.0"
  },
  "dependencies": {
    "@noble/ed25519": "^2.0.0",
    "@scure/base": "^1.1.0"
  },
  "devDependencies": {
    "@near-wallet-selector/core": "^8.9.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
